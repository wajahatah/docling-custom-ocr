# ──────────────────────────────────────────────
# OCR Backend Selection
# ──────────────────────────────────────────────
# Which OCR engine to use.
# Options: custom_api | surya
OCR_BACKEND=custom_api

# ──────────────────────────────────────────────
# Custom OCR API Settings  (used when OCR_BACKEND=custom_api)
# ──────────────────────────────────────────────
# Primary OCR service endpoint
CUSTOM_OCR_API_URL=https://your-ocr-service.example.com/ocr

# Request timeout in seconds
CUSTOM_OCR_TIMEOUT=300

# ──────────────────────────────────────────────
# FastAPI Service
# ──────────────────────────────────────────────
# Port the chunking service listens on
SERVICE_PORT=8100

# ──────────────────────────────────────────────
# Docling Plugin Settings
# ──────────────────────────────────────────────
# Must be true for the custom OCR plugin to be discovered
DOCLING_ALLOW_EXTERNAL_PLUGINS=true
